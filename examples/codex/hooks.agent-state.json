{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/scripts/agent-state.sh running",
            "statusMessage": "marking pane running"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/scripts/agent-state.sh idle",
            "statusMessage": "marking pane idle"
          }
        ]
      }
    ]
  }
}
