#!/usr/bin/env bash
set -euo pipefail

# bash >= 4.2 per associative arrays e [[ -v arr[key] ]]
if ((BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 2))); then
  if command -v tmux >/dev/null 2>&1; then
    tmux display-message 'tmux-picker: serve bash >= 4.2'
  else
    printf 'tmux-picker: serve bash >= 4.2\n' >&2
  fi
  exit 1
fi

self="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/$(basename -- "${BASH_SOURCE[0]}")"
mode="${TMUX_PICKER_MODE:-default}"
git_status_script="$HOME/.tmux/scripts/git-pane-status.sh"

c_reset=$'\033[0m'
c_dim=$'\033[38;5;244m'
c_session=$'\033[38;5;255m'
c_repo=$'\033[38;5;81m'
c_pane=$'\033[38;5;246m'
c_sp=$'\033[38;5;141m'      # specialist (sp-*) badge: violet
c_stale=$'\033[38;5;130m'   # orphan/finished-but-open specialist: dark amber

run_git() {
  if command -v timeout >/dev/null 2>&1; then
    timeout 0.7 git "$@" 2>/dev/null
  else
    git "$@" 2>/dev/null
  fi
}

paint() {
  REPLY="$1${*:2}$c_reset"
}

sanitize_osc() {
  sed -E $'s/\x1b\][^\x1b\x07]*(\x07|\x1b\\\\)//g'
}

capture_pane_safe() {
  local target="$1"
  local start="$2"
  local out
  out="$(tmux capture-pane -p -e -t "$target" -S "$start" 2>/dev/null)" || {
    printf '(pane non leggibile)\n'
    return 0
  }
  printf '%s\n' "$out" | sanitize_osc
}

# Stati normalizzati: needs-input | done | running | idle | ""
# Sorgente primaria: @agent_state scritto dagli hook agent. Questo include anche pi.
normalize_agent_state() {
  local pane_id="$1"
  local opt="$2"
  local cmd="$3"
  local tail

  case "$opt" in
    needs-input|permission|waiting|input) REPLY='needs-input'; return 0 ;;
    done|finished|stop|complete)          REPLY='done';        return 0 ;;
    running|thinking|busy|tool)           REPLY='running';     return 0 ;;
    ''|-|off|idle|none) ;;
    *) REPLY="$opt"; return 0 ;;
  esac

  [ "${TMUX_PICKER_AGENT:-0}" = '1' ] || { REPLY=''; return 0; }

  case "$cmd" in
    claude|codex|aider|cursor|node|python|python3|ollama|llm|opencode|pi) ;;
    *) REPLY=''; return 0 ;;
  esac

  tail="$(tmux capture-pane -p -t "$pane_id" -S -3 2>/dev/null | tr -d '\r')"
  [ -n "$tail" ] || { REPLY='idle'; return 0; }

  if printf '%s' "$tail" | grep -qiE 'do you want|allow|approve|\(y/n\)|permission|press enter|waiting for|\? '; then
    REPLY='needs-input'
  elif printf '%s' "$tail" | grep -qiE 'esc to interrupt|thinking|working|running|generating|compiling|[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]'; then
    REPLY='running'
  else
    REPLY='idle'
  fi
}

agent_rank() {
  case "$1" in
    needs-input) REPLY=0 ;;
    done)        REPLY=1 ;;
    running)     REPLY=2 ;;
    *)           REPLY=3 ;;
  esac
}

state_badge() {
  case "$1" in
    needs-input) REPLY=$'\033[38;5;214m[wait]'"$c_reset" ;;
    done)        REPLY=$'\033[38;5;78m[done]'"$c_reset" ;;
    running)     REPLY=$'\033[38;5;81m[run]'"$c_reset" ;;
    idle)        REPLY="${c_dim}[idle]${c_reset}" ;;
    *) REPLY='' ;;
  esac
}

# --- specialist (sp-*) awareness (xtmux-rib.4) -----------------------------
# detection is name + pane_pid based (no capture-pane cost). a pane is specialist
# if its session name matches ^sp-<role>-<hex>$ and the pane_pid is alive.
#
# hot list path never calls sp/jq/ps/pgrep: it only checks session name + pane
# pid. preview may inspect the pane process tree to extract --bead, but the picker
# does not call `sp ps` or read specialists job db in normal operation.
# hot list shows sp-* as pane rows only; stale/running process state is preview-only
# unless an explicit @agent_state is present (e.g. needs-input -> [wait]).

# sp_role_from_name <session_name> -> REPLY=role (or empty)
sp_role_from_name() {
  local name="$1"
  REPLY=''
  [[ "$name" =~ ^sp-([a-z][a-z0-9-]*)-[0-9a-f]+$ ]] || return 0
  REPLY="${BASH_REMATCH[1]}"
}

# sp_hash_from_name <session_name> -> REPLY=6-ish suffix hash (or empty)
sp_hash_from_name() {
  local name="$1"
  REPLY=''
  [[ "$name" =~ ^sp-[a-z][a-z0-9-]*-([0-9a-f]+)$ ]] || return 0
  REPLY="${BASH_REMATCH[1]}"
}

# sp_is_specialist <session_name> <pane_pid> -> REPLY=role if specialist else empty
sp_is_specialist() {
  local name="$1" pid="$2"
  sp_role_from_name "$name"
  [ -n "$REPLY" ] || return 0
  # pane must be alive. -0 kills with signal 0 (no-op test).
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null || REPLY=''
}

# sp_bead_from_pane <pane_pid> -> REPLY=bead id (or empty), via child cmdline.
# the specialists bun process is a child of the pane shell; its cmdline carries
# --bead <id>. tolerant: returns empty if not found.
sp_bead_from_pane() {
  local pid="$1" proc cmdline
  REPLY=''
  [ -n "$pid" ] || return 0
  for proc in "$pid" $(pgrep -P "$pid" 2>/dev/null || true); do
    [ -n "$proc" ] || continue
    cmdline="$(ps -o args= -p "$proc" 2>/dev/null | head -1 || true)"
    if [[ "$cmdline" =~ --bead[[:space:]]+([^[:space:]]+) ]]; then
      REPLY="${BASH_REMATCH[1]}"
      return 0
    fi
  done
}

# sp_proc_state_from_pane <pane_pid> -> REPLY=running|'' via process tree.
# preview-only. detects a live specialists runner/feed process without calling sp.
sp_proc_state_from_pane() {
  local pid="$1" proc cmdline
  REPLY=''
  [ -n "$pid" ] || return 0
  for proc in "$pid" $(pgrep -P "$pid" 2>/dev/null || true); do
    [ -n "$proc" ] || continue
    cmdline="$(ps -o args= -p "$proc" 2>/dev/null | head -1 || true)"
    case "$cmdline" in
      *'/specialists/dist/index.js run '*|*'/specialists/dist/index.js feed '*|*' specialists/dist/index.js run '*|*' specialists/dist/index.js feed '*)
        REPLY='running'
        return 0
        ;;
    esac
  done
}

# sp_meta <session_name> <pane_pid> -> sets globals sp_role sp_bead sp_state sp_stale
# one-stop resolution for a specialist pane. sp_stale=1 means the pane is alive
# but there is no explicit live specialist state, so it is a cleanup target.
sp_role=''; sp_bead=''; sp_state=''; sp_stale=''
sp_meta() {
  sp_role=''; sp_bead=''; sp_state=''; sp_stale=''
  sp_is_specialist "$1" "$2"
  sp_role="$REPLY"
  [ -n "$sp_role" ] || return 0
  sp_bead_from_pane "$2"; sp_bead="$REPLY"
  sp_proc_state_from_pane "$2"; sp_state="$REPLY"
  # no `sp ps` integration by design: it was too slow/unreliable for the picker.
  # preview can inspect process tree: if no runner/feed is alive, mark stale.
  [ -z "$sp_state" ] && sp_stale=1 || sp_stale='' 
}

# sp_badge -> REPLY = colored [sp] + optional [stale]. used in render_pane_line.
sp_badge() {
  local out
  paint "$c_sp" '[sp]'; out="$REPLY"
  if [ "${sp_stale:-0}" = 1 ]; then
    out+=" "
    paint "$c_stale" '[stale]'; out+="$REPLY"
  fi
  REPLY="$out"
}

short_path() {
  local p="${1:-}"
  [ -n "$p" ] || { REPLY=''; return 0; }
  if [[ "$p" == "$HOME"* ]]; then
    p="~${p#$HOME}"
  fi

  local parts
  IFS='/' read -r -a parts <<< "$p"
  local n=${#parts[@]}
  if [ "$n" -le 4 ]; then
    REPLY="$p"
    return
  fi

  REPLY="…/${parts[$((n-3))]}/${parts[$((n-2))]}/${parts[$((n-1))]}"
}

short_rel_path() {
  local rel="${1:-}"
  [ -n "$rel" ] || { REPLY=''; return 0; }

  local parts
  IFS='/' read -r -a parts <<< "$rel"
  local n=${#parts[@]}
  if [ "$n" -le 2 ]; then
    REPLY="$rel"
    return
  fi

  REPLY="…/${parts[$((n-2))]}/${parts[$((n-1))]}"
}

relative_hint() {
  local pane_path="${1:-}"
  local root="${2:-}"
  [ -n "$pane_path" ] || { REPLY=''; return 0; }
  [ -n "$root" ] || { REPLY=''; return 0; }
  [ "$pane_path" != "$root" ] || { REPLY=''; return 0; }

  local rel="${pane_path#"$root"/}"
  [ "$rel" != "$pane_path" ] || { REPLY=''; return 0; }
  short_rel_path "$rel"   # sets REPLY
}

git_root_for_path() {
  local p="${1:-}"
  [ -n "$p" ] || { REPLY=''; return 0; }
  REPLY="$(run_git -C "$p" rev-parse --show-toplevel 2>/dev/null || true)"
}

# group_root_for_path <pane_path> <git_root> -> REPLY=sort/group key
# keep git status/display tied to the actual worktree, but group known xtrm/tmux
# worktree layouts under their parent repo so sp-* jobs don't float as separate
# top-level repos in the picker.
group_root_for_path() {
  local pane_path="${1:-}"
  local root="${2:-}"
  local base=''

  case "$pane_path" in
    */.xtrm/worktrees/*) base="${pane_path%%/.xtrm/worktrees/*}" ;;
    */.worktrees/*)      base="${pane_path%%/.worktrees/*}" ;;
  esac

  if [ -n "$base" ] && { [ -d "$base/.git" ] || [ -f "$base/.git" ]; }; then
    REPLY="$base"
    return 0
  fi

  REPLY="${root:-$pane_path}"
}

status_for_path() {
  local pane_id="${1:-}"
  local pane_path="${2:-}"

  if [ -x "$git_status_script" ]; then
    if [ -z "$pane_id" ] && [ -n "$pane_path" ]; then
      # path is already the resolved repo toplevel (build_list resolves it
      # first); tell the status script so it skips a redundant rev-parse.
      REPLY="$(TMUX_GIT_TOPLEVEL="$pane_path" "$git_status_script" "" "$pane_path" 2>/dev/null)" || short_path "$pane_path"
    else
      REPLY="$("$git_status_script" "$pane_id" "$pane_path" 2>/dev/null)" || short_path "$pane_path"
    fi
  else
    short_path "$pane_path"
  fi
}

status_meta_from_root_status() {
  local raw="${1:-}"
  local rest meta

  [ -n "$raw" ] || { REPLY=''; return 0; }
  rest="${raw#* }"
  if [ "$rest" = "$raw" ]; then
    REPLY="$raw"
    return 0
  fi

  case "$rest" in
    *'  '*) meta="${rest%%  *}" ;;
    *' path '*) meta="${rest%% path *}" ;;
    *) meta="$rest" ;;
  esac

  REPLY="$meta"
}

render_list_status() {
  local pane_path="${1:-}"
  local root="${2:-}"
  local root_status="${3:-}"
  local repo meta rel out

  if [ -z "$root" ]; then
    short_path "$pane_path"
    paint "$c_dim" "$REPLY"   # sets REPLY
    return 0
  fi

  repo="${root##*/}"
  status_meta_from_root_status "$root_status"; meta="$REPLY"
  relative_hint "$pane_path" "$root"; rel="$REPLY"

  paint "$c_repo" "$repo"; out="$REPLY"
  [ -n "$meta" ] && out+=" $meta"
  if [ -n "$rel" ]; then paint "$c_dim" "· $rel"; out+=" $REPLY"; fi
  REPLY="$out"
}

pane_location_hint() {
  local pane_path="${1:-}"
  local root="${2:-}"
  local repo rel out

  if [ -z "$root" ]; then
    short_path "$pane_path"
    paint "$c_dim" "$REPLY"   # sets REPLY
    return 0
  fi

  repo="${root##*/}"
  relative_hint "$pane_path" "$root"; rel="$REPLY"

  paint "$c_repo" "$repo"; out="$REPLY"
  if [ -n "$rel" ]; then paint "$c_dim" "· $rel"; out+=" $REPLY"; fi
  REPLY="$out"
}

session_meta() {
  tmux list-sessions -F $'#{session_id}\t#{session_name}\t#{pane_id}\t#{pane_current_path}'
}

pane_meta() {
  tmux list-panes -a -F $'#{session_id}\t#{window_index}\t#{window_name}\t#{pane_id}\t#{pane_index}\t#{pane_active}\t#{pane_current_command}\t#{pane_current_path}\t#{?@agent_state,#{@agent_state},-}\t#{pane_pid}'
}

render_pane_line() {
  local window_index="$1"
  local window_name="$2"
  local pane_id="$3"
  local pane_active="$4"
  local pane_cmd="$5"
  local pane_path="$6"
  local root="$7"
  local state="${8:-}"
  local session_name="${9:-}"
  local pane_pid="${10:-}"
  local marker cmd badge loc out sp_badge_str role_str

  marker=' '
  [ "$pane_active" = '1' ] && marker='*'
  cmd="${pane_cmd:-shell}"
  state_badge "$state"; badge="$REPLY"
  pane_location_hint "$pane_path" "$root"; loc="$REPLY"

  # specialist awareness (xtmux-rib.4): fast list path uses session name + live
  # pane pid only. bead/job details are resolved in preview to keep list warm fast.
  sp_is_specialist "$session_name" "$pane_pid"; sp_role="$REPLY"
  sp_bead=''; sp_state=''; sp_stale='' 

  paint "$c_pane" "    ↳ $marker $window_index:$window_name $pane_id"; out="$REPLY"
  if [ -n "$sp_role" ]; then
    sp_badge; sp_badge_str="$REPLY"
    out+=" $sp_badge_str"
    # show real state badges for specialists too (e.g. [wait] in the waiting
    # filter). do not show the synthetic [done] used only to rank stale cleanup.
    if [ -n "$badge" ] && ! { [ "${sp_stale:-0}" = 1 ] && [ -z "$sp_state" ] && [ "$state" = 'done' ]; }; then
      out+=" $badge"
    fi
    paint "$c_sp" "$sp_role"; role_str="$REPLY"
    [ -n "$sp_bead" ] && role_str+=" $c_dim· $sp_bead$c_reset"
    out+=" $role_str"
  else
    [ -n "$badge" ] && out+=" $badge"
    paint "$c_dim" "$cmd"; out+=" $REPLY"
  fi
  [ -n "$loc" ] && out+="  $loc"
  REPLY="$out"
}

# build_list [all|waiting|running]
build_list() {
  local filter="${1:-all}"
  local tmp_sessions tmp_panes sid sname pane_id pane_path root sort_key group_key display root_status name_width=12 session_col
  local window_index window_name pane_index pane_active pane_cmd pane_row_path pane_col pane_state pane_rank cur_rank
  local psid pwi ppi ppid pcol attn sp_role_for_session
  declare -A root_cache=()
  declare -A root_status_cache=()
  declare -A sess_name=()
  declare -A sess_attn=()
  declare -A sess_is_sp=()
  declare -A pane_block=()

  # Persistent git cache (path -> root, root -> status). The expensive, near-static
  # half of the list. Agent state (@agent_state) and the attention sort derived
  # from it are NEVER cached — they're read fresh every call (see xtmux-rib.17).
  local _gcd _gcf _gnow _gmt _ghit=0 _gp _gr _gs
  _gcd="${TMPDIR:-/tmp}/tmux-picker-cache-${UID:-$(id -u)}"
  _gcf="$_gcd/git-table"
  if [ "${TMUX_PICKER_NO_CACHE:-0}" != '1' ] && [ -f "$_gcf" ]; then
    _gnow=$(date +%s)
    _gmt=$(stat -c %Y "$_gcf" 2>/dev/null || echo 0)
    if [ "$_gmt" -gt 0 ] && (( _gnow - _gmt < ${TMUX_PICKER_GIT_CACHE_TTL:-30} )); then
      while IFS=$'\t' read -r _gp _gr _gs; do
        [ -n "$_gp" ] || continue
        root_cache["$_gp"]="$_gr"
        [ -n "$_gr" ] && root_status_cache["$_gr"]="$_gs"
      done < "$_gcf"
      _ghit=1
    fi
  fi

  tmp_sessions="$(mktemp)"
  tmp_panes="$(mktemp)"
  trap 'rm -f "${tmp_sessions:-}" "${tmp_panes:-}"' RETURN EXIT INT TERM

  while IFS=$'\t' read -r sid sname pane_id pane_path; do
    [ -n "$sid" ] || continue
    pane_path="${pane_path:-$HOME}"

    if [[ -v root_cache["$pane_path"] ]]; then
      root="${root_cache[$pane_path]}"
    else
      git_root_for_path "$pane_path"; root="$REPLY"
      root_cache["$pane_path"]="$root"
    fi

    if [ -n "$root" ]; then
      if [[ -v root_status_cache["$root"] ]]; then
        root_status="${root_status_cache[$root]}"
      else
        status_for_path "" "$root"; root_status="$REPLY"
        root_status_cache["$root"]="$root_status"
      fi
    else
      root_status=''
    fi

    group_root_for_path "$pane_path" "$root"; group_key="$REPLY"
    sort_key="$group_key"
    render_list_status "$pane_path" "$root" "$root_status"; display="$REPLY"
    sess_name["$sid"]="$sname"
    sp_role_from_name "$sname"; sp_role_for_session="$REPLY"
    [ -n "$sp_role_for_session" ] && sess_is_sp["$sid"]=1
    if [ -z "$sp_role_for_session" ]; then
      [ "${#sname}" -gt "$name_width" ] && name_width="${#sname}"
    fi

    printf '%s\t%s\t%s\t%s\n' "$sort_key" "$sid" "$sname" "$display" >> "$tmp_sessions"
  done < <(session_meta)

  while IFS=$'\t' read -r sid window_index window_name pane_id pane_index pane_active pane_cmd pane_row_path pane_state pane_pid; do
    [ -n "$sid" ] || continue
    pane_row_path="${pane_row_path:-$HOME}"

    if [[ -v root_cache["$pane_row_path"] ]]; then
      root="${root_cache[$pane_row_path]}"
    else
      git_root_for_path "$pane_row_path"; root="$REPLY"
      root_cache["$pane_row_path"]="$root"
    fi

    normalize_agent_state "$pane_id" "$pane_state" "$pane_cmd"; pane_state="$REPLY"
    # specialist state takes precedence when tracked: a waiting specialist should
    # rank for attention like a waiting agent pane (xtmux-rib.4).
    # fast specialist detection for list hot path: session name + live pane pid.
    # no pgrep/ps/sp here; bead/details are resolved in preview only. do not
    # synthesize stale/running state without process-tree evidence; explicit
    # @agent_state is the only state source in the hot list path.
    sp_is_specialist "${sess_name[$sid]:-}" "$pane_pid"; sp_role="$REPLY"
    agent_rank "$pane_state"; pane_rank="$REPLY"
    cur_rank="${sess_attn[$sid]:-3}"
    [ "$pane_rank" -lt "$cur_rank" ] && sess_attn["$sid"]="$pane_rank"

    render_pane_line "$window_index" "$window_name" "$pane_id" "$pane_active" "$pane_cmd" "$pane_row_path" "$root" "$pane_state" "${sess_name[$sid]:-}" "$pane_pid"; pane_col="$REPLY"
    printf '%s\t%s\t%s\t%s\t%s\n' "$sid" "$window_index" "$pane_index" "$pane_id" "$pane_col" >> "$tmp_panes"
  done < <(pane_meta)

  if [ -s "$tmp_panes" ]; then
    while IFS=$'\t' read -r psid pwi ppi ppid pcol; do
      [ -n "$psid" ] || continue
      pane_block["$psid"]+="$(printf 'pane\t%s\t%s\t%s\t%s' "$psid" "${sess_name[$psid]:-}" "$ppid" "$pcol")"$'\n'
    done < <(sort -t $'\t' -k1,1 -k2,2n -k3,3n "$tmp_panes")
  fi

  # Persist the git cache if this call was a miss. Agent state is deliberately
  # excluded — only path/root/status (near-static, expensive) is stored.
  if [ "$_ghit" = '0' ] && [ "${TMUX_PICKER_NO_CACHE:-0}" != '1' ]; then
    mkdir -p "$_gcd"
    local _gtmp="$_gcf.tmp.$$"
    {
      for _gp in "${!root_cache[@]}"; do
        _gr="${root_cache[$_gp]}"
        _gs=""
        [ -n "$_gr" ] && _gs="${root_status_cache[$_gr]:-}"
        printf '%s\t%s\t%s\n' "$_gp" "$_gr" "$_gs"
      done
    } > "$_gtmp" 2>/dev/null && mv -f "$_gtmp" "$_gcf"
  fi

  [ "$name_width" -gt 22 ] && name_width=22

  while IFS=$'\t' read -r sort_key sid sname display; do
    printf '%s\t%s\t%s\t%s\t%s\n' "${sess_attn[$sid]:-3}" "$sort_key" "$sid" "$sname" "$display"
  done < "$tmp_sessions" |
    sort -t $'\t' -k1,1n -k2,2 -k4,4 |
    while IFS=$'\t' read -r attn _ sid sname display; do
      case "$filter" in
        waiting) [ "$attn" -eq 0 ] || continue ;;
        running) [ "$attn" -le 2 ] || continue ;;
      esac
      if [ "${sess_is_sp[$sid]:-0}" = '1' ]; then
        # sp-* tmux sessions are implementation detail: show their panes directly
        # in the repo bucket instead of as standalone top-level session rows.
        printf '%s' "${pane_block[$sid]:-}"
        continue
      fi
      printf -v session_col '%-*s' "$name_width" "$sname"
      paint "$c_session" "$session_col"; session_col="$REPLY"
      printf 'session\t%s\t%s\t%s\t  %s  %s\n' "$sid" "$sname" "$sid" "$session_col" "$display"
      printf '%s' "${pane_block[$sid]:-}"
    done
}

attn_list() {
  local sid sname pane_id pane_cmd activity pane_state pane_pid rank
  while IFS=$'	' read -r sid sname pane_id pane_cmd activity pane_state pane_pid; do
    [ -n "$pane_id" ] || continue
    normalize_agent_state "$pane_id" "$pane_state" "$pane_cmd"; pane_state="$REPLY"
    sp_is_specialist "$sname" "$pane_pid"; sp_role="$REPLY"
    # no synthetic specialist state here: attn-jump/waiting use explicit
    # @agent_state only for sp panes, keeping the hot path truthful.
    agent_rank "$pane_state"; rank="$REPLY"
    [ "$rank" -le 1 ] || continue
    printf '%s	%s	%s	%s
' "$rank" "${activity:-0}" "$sid" "$pane_id"
  done < <(tmux list-panes -a -F $'#{session_id}	#{session_name}	#{pane_id}	#{pane_current_command}	#{window_activity}	#{?@agent_state,#{@agent_state},-}	#{pane_pid}') |
    sort -t $'	' -k1,1n -k2,2nr
}

record_prev() {
  local cur_pane cur_sid
  cur_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  cur_sid="$(tmux display-message -p '#{session_id}' 2>/dev/null || true)"
  [ -n "$cur_pane" ] && tmux set -g @picker_prev "$cur_sid:$cur_pane" 2>/dev/null || true
}

attn_jump() {
  local n="${1:-1}" line sid pane
  line="$(attn_list | sed -n "${n}p")"
  if [ -z "$line" ]; then
    tmux display-message "tmux-picker: nessun agente in attesa #$n"
    return 0
  fi
  IFS=$'\t' read -r _ _ sid pane <<< "$line"
  jump_to_target pane "$sid" "$pane"
}

jump_back() {
  local prev sid pane
  prev="$(tmux show -gv @picker_prev 2>/dev/null || true)"
  if [ -z "$prev" ]; then
    tmux display-message 'tmux-picker: nessun pane precedente'
    return 0
  fi
  sid="${prev%%:*}"
  pane="${prev#*:}"
  jump_to_target pane "$sid" "$pane"
}

preview_session_row() {
  local sid="$1"
  local name="$2"
  local pane_path root root_name rel attached window_count pane_count
  local window_index window_name pane_id pane_index pane_active pane_cmd pane_row_path pane_width pane_height pane_left pane_top pane_state pane_pid
  local pane_root pane_loc active_mark hdr panes_raw first_pane_pid sp_hash sp_view_state bd_line
  declare -A root_cache=()

  pane_path="$(tmux display-message -p -t "$sid" '#{pane_current_path}' 2>/dev/null || true)"
  pane_path="${pane_path:-$HOME}"
  hdr="$(tmux display-message -p -t "$sid" $'#{session_attached}\t#{session_windows}' 2>/dev/null || true)"
  attached="${hdr%%$'\t'*}"
  window_count="${hdr#*$'\t'}"
  [ "$attached" = "$hdr" ] && attached='0'
  [ "$window_count" = "$hdr" ] && window_count='?'

  git_root_for_path "$pane_path"; root="$REPLY"
  root_name="${root:+${root##*/}}"

  if [ -n "$root" ] && [ "$pane_path" != "$root" ]; then
    relative_hint "$pane_path" "$root"; rel="$REPLY"
  else
    rel=''
  fi

  # Single scoped call: only this session's panes (was list-panes -a | awk, twice).
  panes_raw="$(tmux list-panes -s -t "$sid" -F $'#{window_index}\t#{window_name}\t#{pane_id}\t#{pane_index}\t#{pane_active}\t#{pane_current_command}\t#{pane_current_path}\t#{pane_width}\t#{pane_height}\t#{pane_left}\t#{pane_top}\t#{?@agent_state,#{@agent_state},-}\t#{pane_pid}' 2>/dev/null || true)"
  if [ -n "$panes_raw" ]; then
    pane_count="$(printf '%s\n' "$panes_raw" | grep -c .)"
  else
    pane_count=0
  fi

  if [ -n "$root_name" ]; then
    printf 'session=%s  root=%s\n' "$name" "$root_name"
  else
    printf 'session=%s\n' "$name"
  fi
  [ -n "$rel" ] && printf 'cwd=%s\n' "$rel"
  first_pane_pid="$(printf '%s\n' "$panes_raw" | awk -F'\t' 'NF{print $13; exit}')"
  sp_meta "$name" "$first_pane_pid"
  if [ -n "$sp_role" ]; then
    sp_hash_from_name "$name"; sp_hash="$REPLY"
    sp_view_state="${sp_state:-}"
    [ -z "$sp_view_state" ] && [ "${sp_stale:-0}" = 1 ] && sp_view_state='stale'
    [ -z "$sp_view_state" ] && sp_view_state='unknown'
    printf 'specialist job=%s bead=%s role=%s state=%s\n' "${sp_hash:-?}" "${sp_bead:-?}" "$sp_role" "$sp_view_state"
    if [ -n "$sp_bead" ] && command -v bd >/dev/null 2>&1; then
      bd_line="$(cd "$pane_path" 2>/dev/null && bd show "$sp_bead" 2>/dev/null | head -1 || true)"
      [ -n "$bd_line" ] && printf 'bead %s\n' "$bd_line"
    fi
  fi
  printf 'windows=%s  panes=%s  attached=%s\n\n' "${window_count:-?}" "${pane_count:-0}" "${attached:-0}"

  while IFS=$'\t' read -r window_index window_name pane_id pane_index pane_active pane_cmd pane_row_path pane_width pane_height pane_left pane_top pane_state pane_pid; do
    pane_row_path="${pane_row_path:-$pane_path}"
    if [[ -v root_cache["$pane_row_path"] ]]; then
      pane_root="${root_cache[$pane_row_path]}"
    else
      git_root_for_path "$pane_row_path"; pane_root="$REPLY"
      root_cache["$pane_row_path"]="$pane_root"
    fi
    pane_location_hint "$pane_row_path" "$pane_root"; pane_loc="$REPLY"
    normalize_agent_state "$pane_id" "$pane_state" "$pane_cmd"; pane_state="$REPLY"
    active_mark=' '
    [ "$pane_active" = '1' ] && active_mark='*'

    printf '[%s:%s.%s%s] %s' "$window_index" "$window_name" "$pane_index" "$active_mark" "${pane_cmd:-shell}"
    [ -n "$pane_state" ] && [ "$pane_state" != '-' ] && printf ' <%s>' "$pane_state"
    printf '  %sx%s +%s+%s' "$pane_width" "$pane_height" "$pane_left" "$pane_top"
    [ -n "$pane_loc" ] && printf '  %s' "$pane_loc"
    printf '\n'
    capture_pane_safe "$pane_id" -8
    printf '\n'
  done < <(printf '%s\n' "$panes_raw")
}

preview_pane_row() {
  local sid="$1"
  local name="$2"
  local target_pane="$3"
  local pane_path root root_name rel attached window_line pane_cmd pane_state pane_pid sp_hash sp_view_state bd_line

  local pinfo
  pinfo="$(tmux display-message -p -t "$target_pane" $'#{pane_current_path}	#{pane_current_command}	#I:#W	#{?@agent_state,#{@agent_state},-}	#{pane_pid}' 2>/dev/null || true)"
  IFS=$'	' read -r pane_path pane_cmd window_line pane_state pane_pid <<< "$pinfo"
  pane_path="${pane_path:-$HOME}"
  git_root_for_path "$pane_path"; root="$REPLY"
  root_name="${root:+${root##*/}}"
  attached="$(tmux display-message -p -t "$sid" '#{session_attached}' 2>/dev/null || true)"
  normalize_agent_state "$target_pane" "$pane_state" "$pane_cmd"; pane_state="$REPLY"

  if [ -n "$root" ] && [ "$pane_path" != "$root" ]; then
    relative_hint "$pane_path" "$root"; rel="$REPLY"
  else
    rel=''
  fi

  if [ -n "$root_name" ]; then
    printf 'session=%s  root=%s
' "$name" "$root_name"
  else
    printf 'session=%s
' "$name"
  fi
  [ -n "$rel" ] && printf 'cwd=%s
' "$rel"

  sp_meta "$name" "$pane_pid"
  if [ -n "$sp_role" ]; then
    sp_hash_from_name "$name"; sp_hash="$REPLY"
    sp_view_state="${sp_state:-}"
    [ -z "$sp_view_state" ] && [ "${sp_stale:-0}" = 1 ] && sp_view_state='stale'
    [ -z "$sp_view_state" ] && sp_view_state='unknown'
    printf 'specialist job=%s bead=%s role=%s state=%s
' "${sp_hash:-?}" "${sp_bead:-?}" "$sp_role" "$sp_view_state"
    if [ -n "$sp_bead" ] && command -v bd >/dev/null 2>&1; then
      bd_line="$(cd "$pane_path" 2>/dev/null && bd show "$sp_bead" 2>/dev/null | head -1 || true)"
      [ -n "$bd_line" ] && printf 'bead %s
' "$bd_line"
    fi
  fi

  printf 'win=%s  pane=%s  cmd=%s' "${window_line:-?}" "$target_pane" "${pane_cmd:-shell}"
  [ -n "$pane_state" ] && [ "$pane_state" != '-' ] && printf '  agent=%s' "$pane_state"
  printf '  attached=%s

' "${attached:-0}"

  capture_pane_safe "$target_pane" -48
}

preview_row() {
  local type="${1:-}"
  local sid="${2:-}"
  local name="${3:-}"
  local target="${4:-}"

  [ -n "$sid" ] || return 0
  case "$type" in
    pane) preview_pane_row "$sid" "$name" "$target" ;;
    *) preview_session_row "$sid" "$name" ;;
  esac
}

open_popup_client() {
  local type="$1"
  local sid="$2"
  local target="$3"

  if [ "$type" = 'pane' ] && [ -n "$target" ]; then
    exec env -u TMUX tmux attach-session -t "$sid" \; select-window -t "$target" \; select-pane -t "$target"
  fi

  exec env -u TMUX tmux attach-session -t "$sid"
}

jump_to_target() {
  local type="$1"
  local sid="$2"
  local target="$3"

  if [ "$type" = 'pane' ] && [ -n "$target" ]; then
    exec tmux switch-client -t "$sid" \; select-window -t "$target" \; select-pane -t "$target"
  fi

  exec tmux switch-client -t "$sid"
}

kill_target() {
  local type="$1"
  local sid="$2"
  local target="$3"

  if [ "$type" = 'pane' ] && [ -n "$target" ]; then
    tmux kill-pane -t "$target"
    return 0
  fi

  tmux kill-session -t "$sid"
}

# act_on_target <type> <sid> <target> <action>
# act on a pane from the list without attaching. no-op on session rows (only
# pane rows carry a usable target). cross-session safe: send-keys -t <pane>.
# actions:
#   approve   -> send 'y Enter'         (yes to a waiting agent permission)
#   interrupt -> send 'C-c'             (cancel the current turn)
#   message   -> prompt the operator for a one-line message, send it + Enter
act_on_target() {
  local type="$1"
  local sid="$2"
  local target="$3"
  local action="$4"
  local toast

  # session rows have no pane target to act on. this guard keeps the binds safe
  # when the highlight lands on a session line.
  if [ "$type" != 'pane' ] || [ -z "$target" ]; then
    tmux display-message "tmux-picker: nessun pane su cui agire (riga sessione)"
    return 0
  fi

  case "$action" in
    approve)
      tmux send-keys -t "$target" 'y' Enter
      toast="approvato $target"
      ;;
    interrupt)
      tmux send-keys -t "$target" C-c
      toast="interrotto $target"
      ;;
    message)
      # command-prompt runs in the picker client; the typed line is then sent
      # to the target pane via send-keys. %1 is command-prompt substitution.
      tmux command-prompt -p 'invia:' "run-shell 'tmux send-keys -t \"$target\" \"%1\" Enter'"
      return 0
      ;;
    *)
      tmux display-message "tmux-picker: azione sconosciuta: $action"
      return 1
      ;;
  esac

  [ -n "$toast" ] && tmux display-message "tmux-picker: $toast"
}

case "${1:-}" in
  list)
    # Output cache removed (xtmux-rib.17): it froze agent-derived sort/badges
    # for the whole TTL. Only the git half is cached (in build_list); the list
    # is always rendered fresh so @agent_state changes are immediate.
    shift
    build_list "${1:-all}"
    exit 0
    ;;
  preview)
    shift
    preview_row "$@"
    exit 0
    ;;
  popup)
    shift
    open_popup_client "$@"
    ;;
  jump)
    shift
    jump_to_target "$@"
    ;;
  kill)
    shift
    kill_target "$@"
    exit 0
    ;;
  act)
    # act-on-preview (xtmux-rib.3): act on the highlighted pane without
    # attaching. actions: approve | interrupt | message. invoked by the fzf
    # binds ctrl-y / alt-i / ctrl-o.
    shift
    act_on_target "$@"
    exit 0
    ;;
  attn-jump)
    shift
    record_prev
    attn_jump "${1:-1}"
    exit 0
    ;;
  jump-back)
    jump_back
    exit 0
    ;;
  "")
    ;;
  *)
    printf 'usage: %s [list [all|waiting|running]|preview <type> <sid> <name> <target>|popup <type> <sid> <target>|jump <type> <sid> <target>|kill <type> <sid> <target>|act <type> <sid> <target> <approve|interrupt|message>|attn-jump <n>|jump-back]\n' "$0" >&2
    exit 2
    ;;
esac

if ! command -v fzf >/dev/null 2>&1; then
  tmux display-message 'fzf non trovato'
  exit 1
fi

preview_window='right,62%,border-left,wrap,follow'
preview_window_max='right,94%,border-left,wrap,follow'
border_label=' Enter switch · Alt-Enter popup · Alt-x kill · ^Y ok · Alt-I int · ^O msg · ^A all ^W wait ^E run · Ctrl-r refresh · Ctrl-/ preview '
case "$mode" in
  compact-wrap)
    preview_window='right,68%,border-left,wrap,follow'
    preview_window_max='right,94%,border-left,wrap,follow'
    border_label=' compact wrap · Enter switch · Alt-Enter popup · Alt-x kill · ^Y approve · Alt-I interrupt · ^O msg · ^A/^W/^E filtri · Ctrl-r refresh '
    ;;
  compact-nowrap)
    preview_window='right,68%,border-left,follow'
    preview_window_max='right,94%,border-left,follow'
    border_label=' compact no-wrap · Enter switch · Alt-Enter popup · Alt-x kill · ^Y approve · Alt-I interrupt · ^O msg · ^A/^W/^E filtri · Ctrl-r refresh '
    ;;
esac

choice="$({
  "$self" list all
} | fzf \
  --ansi \
  --delimiter=$'\t' \
  --with-nth=5 \
  --layout=reverse-list \
  --height=100% \
  --border=sharp \
  --border-label "$border_label" \
  --border-label-pos='3:bottom' \
  --no-scrollbar \
  --cycle \
  --no-bold \
  --prompt='all> ' \
  --pointer='>' \
  --marker='' \
  --info=inline-right \
  --color='fg:#b8bcc0,bg:-1,hl:#ffffff,fg+:#ffffff,bg+:#222222,hl+:#ffffff,info:#8a8f94,prompt:#8a8f94,pointer:#c6cacf,marker:#c6cacf,label:#8a8f94,border:#303030,gutter:-1' \
  --preview-window="$preview_window" \
  --bind="ctrl-/:toggle-preview" \
  --bind="ctrl-r:reload(TMUX_PICKER_NO_CACHE=1 $self list all)" \
  --bind="ctrl-a:change-prompt(all> )+reload($self list all)" \
  --bind="ctrl-w:change-prompt(wait> )+reload($self list waiting)" \
  --bind="ctrl-e:change-prompt(run> )+reload($self list running)" \
  --bind="alt-p:change-preview-window($preview_window_max|$preview_window)" \
  --bind="alt-x:execute-silent($self kill {1} {2} {4})+reload($self list all)" \
  --bind="ctrl-y:execute-silent($self act {1} {2} {4} approve)+reload($self list all)" \
  --bind="alt-i:execute-silent($self act {1} {2} {4} interrupt)+reload($self list all)" \
  --bind="ctrl-o:execute($self act {1} {2} {4} message)+reload($self list all)" \
  --bind="alt-enter:become($self popup {1} {2} {4})" \
  --preview "$self preview {1} {2} {3} {4}"
)" || true

[ -n "${choice:-}" ] || exit 0
IFS=$'\t' read -r type sid name target _ <<< "$choice"
jump_to_target "$type" "$sid" "$target"
